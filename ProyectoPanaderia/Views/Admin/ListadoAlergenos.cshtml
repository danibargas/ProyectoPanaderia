@model List<ProyectoPanaderia.Models.Entidades.Alergenos>

<style>
    main {
        display: flex;
        justify-content: center;
    }
</style>

<div class="justify-content-center">
    <table class="table table-borderless">
        <thead>
            <tr>
                <th>IDALERGENO</th>
                <th>DESCRIPCION</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.IdAlergeno</td>
                    <td>@item.Descripcion</td>
                    <td>
                        <button class="btn btn-danger" id="eliminar" data-idalergeno="@item.IdAlergeno">Eliminar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts{
    <script>
        $(document).ready(function () {
            $('.btn').on('click', function () {
                var idalergeno = $(this).data('idalergeno');
                $.ajax({
                    url: '/admin/eliminaralergeno',
                    type: 'POST',
                    data: { idalergeno: idalergeno },
