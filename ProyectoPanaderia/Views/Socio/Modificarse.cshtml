@model ProyectoPanaderia.Models.Entidades.Socio

<div class="row justify-content-center">
    <div class="col-sm-8 mt-5">
        <div class="card">
            <div class="card-body justify-content-center">
                <form action="/socio/modificarse/@Model.IdSocio" method="post">
                    <div style="text-align: center" class="justify-content-center">
                        <h5 class="card-title">Datos personales de: @Model.NickName</h5>
                        @if (TempData["error"] != null)
                        {
                            <div class="alert alert-danger col-12">@TempData["error"]</div>
                        }
                    </div>
                    <div class="mb-3 mt-lg-5 row justify-content-center">
                        <div class="col-5">
                            <span>Nombre</span>
                        </div>
                        <div class="col-4">
                            <input type="text"name="nombre" value="@Model.Nombre" class="form-control" required />
                        </div>
                    </div>

                    <div class="mb-3 row justify-content-center">
                        <div class="col-5">
                            <span>Apellidos</span>
                        </div>
                        <div class="col-4">
                            <input type="text" name="apellidos" value="@Model.Apellidos" class="form-control" required />
                        </div>
                    </div>

                    <div class="mb-3 row justify-content-center">
                        <div class="col-5">
                            <span>Nickname</span>
                        </div>
                        <div class="col-4">
                            <input type="text" name="nick" value="@Model.NickName" class="form-control" disabled/>
                        </div>
                    </div>

                    <div class="mb-3 row justify-content-center">
                        <div class="col-5">
                            <span>Email:</span>
                        </div>
                        <div class="col-4">
                            <input type="email" name="email" value="@Model.Email" class="form-control" required />
                        </div>
                    </div>
                    <div class="mb-3 row justify-content-center">
                        <div class="col-5">
                            <span>Contraseña</span>
                        </div>
                        <div class="col-4">
                            <input type="text" name="cont" value="@Model.Contraseña" class="form-control" required />
                        </div>
                    </div>

                    <div class="mb-3 row justify-content-center">
                        <div class="col-5">
                            <span>Repetir contraseña</span>
                        </div>
                        <div class="col-4">
                            <input type="text" name="cont2" value="@Model.Contraseña" class="form-control" required />
                        </div>
                    </div>

                    <div class="mb-3 row justify-content-center">
                        <div class="col-5">
                            <span>Fecha de nacimiento</span>
                        </div>
                        <div class="col-4">
                            <input type="date" id="fecha" name="fecha" value="@Model.FechaNacimiento.ToString("yyyy-MM-dd")" class="form-control" required />
                        </div>
                    </div>
                    <div class="mb-3 mt-5 row justify-content-center">
                        <input type="submit" value="Confirmar cambios" class="btn-outline-primary col-3" />
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts{
    <script>
        $(document).ready(function () {
            $('#fecha').focusout('input', function () {
                console.log($('#fecha').val());
            });
        });

    </script>
}
