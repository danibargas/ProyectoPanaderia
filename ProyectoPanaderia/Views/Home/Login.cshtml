@{
    ViewData["Title"] = "Home Page";
    Layout = null;
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/css/bootstrap.min.css" rel="stylesheet"
      integrity="sha384-iYQeCzEYFbKjA/T2uDLTpkwGzCiq6soy8tYaI1GyVh/UjpbCx/TYkiZhlZB6+fzT" crossorigin="anonymous">
<style>
    body {
        display: flex;
        justify-content: center;
        margin-top: 10em;
    }

    .row {
        align-items: center;
        margin-left: 3em;
    }

    .card {
        border: 1px solid black;
    }
</style>
<div class="card" style="width: 40rem; height: 22em;">
    <div class="card-body">
        <div class="mb-5" style="text-align: center;">
            <h3>Log in!</h3>
        </div>
        <form action="/home/login" method="post">
            <div class="mb-3 row" style="align-items: center;">
                <div class="col-sm-3">Nickname</div>
                <div class="col-sm-5">
                    <input type="text" class="form-control" id="nick" name="nick" />
                </div>
            </div>
            <div class="mb-3 row" style="margin-left: 3em;">
                <div class="col-sm-3">Password</div>
                <div class="col-sm-5">
                    <input type="text" class="form-control" id="contraseña" name="contraseña">
                </div>
            </div>
            <div class="col-sm-12 mt-4" style="display: flex; justify-content: center; text-align: center">
                <input type="submit" value="Iniciar sesion" class="btn btn-primary">
            </div>
            <div class="col-sm-12 mt-4" style="display: flex; justify-content: center; text-align: center">
                <p>¿Aún no tienes cuenta? <a href="/home/registro">Registrate</a></p>
            </div>

        </form>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    $(document).ready(function () {
        $('#nick').focusout('input', function () {
            console.log("hola");
        });
    });
</script>